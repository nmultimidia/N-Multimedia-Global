# ============================================================
# N Multimídia — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/nmultimidia

# Frontend (React/Vite)
PORT=3000
BASE_PATH=/

# API Server
# PORT and BASE_PATH are set per workflow
# API_SERVER_PORT is used by the frontend proxy
API_SERVER_PORT=8080

# E-mail (SMTP) — configure via CRM Settings UI or here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@youragency.com
